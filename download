"use client";

import { useState } from "react";
import { useRouter } from "next/navigation";

export function ReviewForm({ productId }: { productId: number }) {
  const router = useRouter();
  const [author, setAuthor] = useState("");
  const [rating, setRating] = useState(5);
  const [title, setTitle] = useState("");
  const [body, setBody] = useState("");
  const [hover, setHover] = useState(0);
  const [status, setStatus] = useState<"idle" | "sending" | "done" | "error">(
    "idle",
  );
  const [error, setError] = useState("");

  const submit = async (e: React.FormEvent) => {
    e.preventDefault();
    setError("");
    if (author.trim().length < 2 || title.trim().length < 2 || body.trim().length < 4) {
      setError("Preencha todos os campos obrigatórios.");
      return;
    }
    setStatus("sending");
    try {
      const res = await fetch("/api/reviews", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ productId, author, rating, title, body }),
      });
      if (!res.ok) throw new Error("Falha ao enviar");
      setStatus("done");
      setAuthor("");
      setTitle("");
      setBody("");
      setRating(5);
      router.refresh();
    } catch {
      setStatus("error");
      setError("Erro ao salvar avaliação. Tente novamente.");
    }
  };

  if (status === "done") {
    return (
      <div className="border border-pine/40 bg-pine/5 p-6 text-center rounded-none mb-8">
        <p className="font-sans font-bold text-lg uppercase text-ink">AVALIAÇÃO REGISTRADA!</p>
        <p className="mt-1 text-xs text-muted uppercase tracking-widest">
          Sua opinião é de extrema importância para o drop.
        </p>
        <button
          type="button"
          onClick={() => setStatus("idle")}
          className="btn btn-outline mt-4 px-5 py-2.5"
        >
          Avaliar outra peça
        </button>
      </div>
    );
  }

  return (
    <form
      onSubmit={submit}
      className="border border-line bg-cream-2/40 p-6 sm:p-8 rounded-none mb-8"
    >
      <h3 className="font-sans font-black text-lg uppercase tracking-wider text-ink flex items-center gap-2">
        <span>🚩</span> REGISTRAR FEEDBACK REALISTA
      </h3>

      <div className="mt-5">
        <label className="mb-2 block text-xs font-black uppercase tracking-wider text-ink">
          Sua nota
        </label>
        <div className="flex gap-1" onMouseLeave={() => setHover(0)}>
          {[1, 2, 3, 4, 5].map((n) => (
            <button
              key={n}
              type="button"
              onMouseEnter={() => setHover(n)}
              onClick={() => setRating(n)}
              aria-label={`${n} estrelas`}
              className="text-2xl leading-none transition-colors"
              style={{ color: (hover || rating) >= n ? "#dc2626" : "#262626" }}
            >
              ★
            </button>
          ))}
        </div>
      </div>

      <div className="mt-5 grid gap-4 sm:grid-cols-2">
        <div>
          <label className="mb-2 block text-xs font-black uppercase tracking-wider text-ink">Nome / Codinome</label>
          <input
            required
            value={author}
            onChange={(e) => setAuthor(e.target.value)}
            className="w-full rounded-none border border-line bg-cream px-4 py-3 text-xs uppercase tracking-wider outline-none focus:border-pine"
            placeholder="Ex: Pedro_K"
          />
        </div>
        <div>
          <label className="mb-2 block text-xs font-black uppercase tracking-wider text-ink">Título do comentário</label>
          <input
            required
            value={title}
            onChange={(e) => setTitle(e.target.value)}
            className="w-full rounded-none border border-line bg-cream px-4 py-3 text-xs uppercase tracking-wider outline-none focus:border-pine"
            placeholder="Ex: Excelente corte drop shoulder"
          />
        </div>
      </div>

      <div className="mt-4">
        <label className="mb-2 block text-xs font-black uppercase tracking-wider text-ink">
          Feedback técnico (caimento, tecido, acabamentos)
        </label>
        <textarea
          required
          value={body}
          onChange={(e) => setBody(e.target.value)}
          rows={4}
          className="w-full resize-none rounded-none border border-line bg-cream px-4 py-3 text-xs uppercase tracking-wider outline-none focus:border-pine"
          placeholder="O caimento ficou oversized? A gramatura do algodão é realmente encorpada? Diga aqui..."
        />
      </div>

      {error && <p className="mt-3 text-xs font-bold text-terracotta uppercase tracking-wider">{error}</p>}

      <button
        type="submit"
        disabled={status === "sending"}
        className="btn btn-dark mt-5 w-full sm:w-auto disabled:opacity-60"
      >
        {status === "sending" ? "REGISTRANDO..." : "PUBLICAR OPINIÃO"}
      </button>
    </form>
  );
}
